{
  "name": "@loom/intent-parser",
  "version": "0.1.0",
  "description": "Intent Parser for Loom game generation platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "ts-node src/integration-test.ts",
    "test:integration:quick": "ts-node src/integration-test.ts quick",
    "test:integration:easy": "ts-node src/integration-test.ts easy",
    "test:e2e": "ts-node src/e2e-test.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@loom/code-generator": "workspace:*",
    "@loom/core": "workspace:*",
    "@loom/llm-client": "workspace:*",
    "@loom/planner": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "loom",
    "game",
    "ai",
    "intent-parser",
    "llm",
    "natural-language"
  ]
}
